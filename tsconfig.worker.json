{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./",
    "isolatedModules": false,
    "paths": { "@/*": ["./*"] }
  },
  "include": [
    "worker/**/*",
    "lib/db.ts",
    "lib/queues.ts",
    "lib/ai.ts",
    "lib/scraper.ts",
    "lib/woocommerce.ts"
  ],
  "exclude": ["node_modules", "app", ".next"]
}