# ── UploadThing ──────────────────────────────────────────────
# Get from: https://uploadthing.com → your app → API Keys
UPLOADTHING_TOKEN=your_uploadthing_token_here
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ── WooCommerce ──────────────────────────────────────────────
# Your store URL (no trailing slash)
WC_URL=https://yourstore.com

# Get from: WooCommerce → Settings → Advanced → REST API → Add Key (Read/Write)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WP_APP_USER=your_wp_admin_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── App ──────────────────────────────────────────────────────
# A secret password to protect your importer UI (can be anything you choose)
APP_PASSWORD=changeme123



# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=yupoo_importer
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/yupoo_importer

# ── Redis (your existing Docker Redis on the VPS) ─────────────────────────
# If Redis is on the host network use host.docker.internal or the VPS LAN IP
REDIS_URL=redis://host.docker.internal:6379

# ── xAI / Grok (text-only, for title translation + description generation) ─
XAI_API_KEY=

# ── Next.js public vars ───────────────────────────────────────────────────
NEXT_PUBLIC_WC_URL=localhost:8000

# ── Worker concurrency ────────────────────────────────────────────────────
SCRAPE_CONCURRENCY=10
IMPORT_CONCURRENCY=15