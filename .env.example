# ── UploadThing ──────────────────────────────────────────────
# Get from: https://uploadthing.com → your app → API Keys
UPLOADTHING_TOKEN=your_uploadthing_token_here
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ── WooCommerce ──────────────────────────────────────────────
# Your store URL (no trailing slash)
WC_URL=https://yourstore.com

# Get from: WooCommerce → Settings → Advanced → REST API → Add Key (Read/Write)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WP_APP_USER=your_wp_admin_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── App ──────────────────────────────────────────────────────
# A secret password to protect your importer UI (can be anything you choose)
APP_PASSWORD=changeme123
